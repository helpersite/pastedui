                Font = theme.font,
                Color = theme.accent,
                Outline = true,
                OutlineColor = theme.shadow,
                Transparency = self.visible and 1 or 0,
                ZIndex = 6
            })
            
            function dropdown:Set(value)
                self.value = value
                self.selectedText.Text = tostring(value)
                
                if flag then
                    finchy.flags[flag] = value
                end
                
                callback(value)
            end
            
            function dropdown:Get()
                return self.value
            end
            
            function dropdown:Toggle()
                self.open = not self.open
                self.arrow.Text = self.open and "^" or "v"
                
                if self.open then
                    -- Create option elements
                    local baseY = self.box.Position.Y + 22
                    
                    -- Options background
                    self.optionsBg = utility:Create("Square", {
                        Position = Vector2.new(self.box.Position.X, baseY),
                        Size = Vector2.new(self.section.width - 16, #self.options * 20 + 4),
                        Color = theme.background,
                        Filled = true,
                        ZIndex = 100
                    })
                    table.insert(self.optionElements, self.optionsBg)
                    
                    -- Options border
                    self.optionsBorder = utility:Create("Square", {
                        Position = Vector2.new(self.box.Position.X, baseY),
                        Size = Vector2.new(self.section.width - 16, #self.options * 20 + 4),
                        Color = theme.inline,
                        Filled = false,
                        Thickness = 1,
                        ZIndex = 101
                    })
                    table.insert(self.optionElements, self.optionsBorder)
                    
                    -- Create each option
                    for i, option in pairs(self.options) do
                        local optY = baseY + 2 + ((i - 1) * 20)
                        
                        local optBg = utility:Create("Square", {
                            Position = Vector2.new(self.box.Position.X + 2, optY),
                            Size = Vector2.new(self.section.width - 20, 18),
                            Color = option == self.value and Color3.fromRGB(45, 45, 45) or theme.background,
                            Filled = true,
                            ZIndex = 102
                        })
                        table.insert(self.optionElements, optBg)
                        
                        local optText = utility:Create("Text", {
                            Position = Vector2.new(self.box.Position.X + 8, optY + 2),
                            Text = option,
                            Size = 12,
                            Font = theme.font,
                            Color = option == self.value and theme.accent or theme.textPrimary,
                            Outline = true,
                            OutlineColor = theme.shadow,
                            ZIndex = 103
                        })
                        table.insert(self.optionElements, optText)
                        
                        -- Store for click detection
                        optBg._option = option
                        optBg._dropdown = self
                    end
                else
                    -- Remove option elements
                    for _, elem in pairs(self.optionElements) do
                        utility:Remove(elem)
                    end
                    self.optionElements = {}
                end
            end
            
            function dropdown:Close()
                if self.open then
                    self.open = false
                    self.arrow.Text = "v"
                    
                    for _, elem in pairs(self.optionElements) do
                        utility:Remove(elem)
                    end
                    self.optionElements = {}
                end
            end
            
            function dropdown:UpdatePosition()
                local s = self.section
                local dw = s.width - 16
                
                self.label.Position = Vector2.new(s.baseX + 8, s.baseY + yPos)
                self.box.Position = Vector2.new(s.baseX + 8, s.baseY + yPos + 16)
                self.boxBorder.Position = Vector2.new(s.baseX + 8, s.baseY + yPos + 16)
                self.selectedText.Position = Vector2.new(s.baseX + 14, s.baseY + yPos + 20)
                self.arrow.Position = Vector2.new(s.baseX + dw - 8, s.baseY + yPos + 19)
                
                if self.open then
                    self:Close()
                end
            end
            
            function dropdown:SetVisible(visible)
                local t = visible and 1 or 0
                self.label.Transparency = t
                self.box.Transparency = t
                self.boxBorder.Transparency = t
                self.selectedText.Transparency = t
                self.arrow.Transparency = t
                
                if not visible and self.open then
                    self:Close()
                end
            end
            
            -- Click handler for dropdown
            table.insert(finchy.began, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and self.visible then
                    -- Check main box click
                    if utility:MouseOver(dropdown.box.Position.X, dropdown.box.Position.Y, self.width - 16, 22) then
                        dropdown:Toggle()
                        return
                    end
                    
                    -- Check option clicks
                    if dropdown.open then
                        local clicked = false
                        for _, elem in pairs(dropdown.optionElements) do
                            if elem._option and utility:MouseOver(elem.Position.X, elem.Position.Y, elem.Size.X, elem.Size.Y) then
                                dropdown:Set(elem._option)
                                dropdown:Close()
                                clicked = true
                                break
                            end
                        end
                        
                        -- Close if clicked outside
                        if not clicked then
                            local totalHeight = #dropdown.options * 20 + 26
                            if not utility:MouseOver(dropdown.box.Position.X, dropdown.box.Position.Y, self.width - 16, totalHeight) then
                                dropdown:Close()
                            end
                        end
                    end
                end
            end)
            
            if flag then
                finchy.flags[flag] = default
                finchy.pointers[flag] = dropdown
            end
            
            table.insert(self.elements, dropdown)
            self.currentY = self.currentY + 44
            
            return dropdown
        end
        
