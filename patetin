function Window:UpdatePosition()
    local x, y = self.position.X, self.position.Y
    local w, h = self.size.X, self.size.Y
    
    self.shadow.Position = Vector2.new(x + 4, y + 4)
    self.background.Position = Vector2.new(x, y)
    self.outerBorder.Position = Vector2.new(x, y)
    self.accentBorder.Position = Vector2.new(x, y)
    self.titleBar.Position = Vector2.new(x + 1, y + 3)
    self.titleText.Position = Vector2.new(x + 10, y + 8)
    self.credits.Position = Vector2.new(x + w - 80, y + 10)
    self.statsText.Position = Vector2.new(x + w - 150, y + 10)
    self.separator.Position = Vector2.new(x + 1, y + 30)
    self.tabContainer.Position = Vector2.new(x + 1, y + 31)
    self.contentSeparator.Position = Vector2.new(x + 1, y + 56)
    self.contentArea.Position = Vector2.new(x + 1, y + 57)
    
    -- Update gradient lines
    for i, line in pairs(self.gradientLines) do
        line.Position = Vector2.new(x + (w / 20) * i, y + 2)
    end
    
    -- Update tabs
    local tabX = x + 10
    for _, tab in pairs(self.tabs) do
        tab.button.Position = Vector2.new(tabX, y + 35)
        tab.underline.Position = Vector2.new(tabX, y + 52)
        tabX = tabX + tab.button.TextBounds.X + 20
        
        -- Update sections
        for _, section in pairs(tab.sections) do
            section:UpdatePosition()
        end
    end
end

function Window:Toggle()
    self.visible = not self.visible
    
    local transparency = self.visible and 1 or 0
    
    for _, obj in pairs(finchy.drawings) do
        if obj and obj.Visible ~= nil then
            pcall(function()
                if obj.Transparency then
                    obj.Transparency = transparency
                end
                obj.Visible = self.visible
            end)
        end
    end
end

function Window:CreateTab(config)
    config = config or {}
    local name = config.Name or config.name or "Tab"
    
    local tab = {
        name = name,
        sections = {},
        visible = false,
        window = self
    }
    
    local tabX = self.position.X + 10
    for _, t in pairs(self.tabs) do
        tabX = tabX + t.button.TextBounds.X + 20
    end
    
    -- Tab button
    tab.button = utility:Create("Text", {
        Position = Vector2.new(tabX, self.position.Y + 35),
        Text = name,
        Size = 13,
        Font = theme.font,
        Color = #self.tabs == 0 and theme.accent or theme.textSecondary,
        Outline = true,
        OutlineColor = theme.shadow,
        ZIndex = 5
    })
    
    -- Tab underline (for active state)
    tab.underline = utility:Create("Square", {
        Position = Vector2.new(tabX, self.position.Y + 52),
        Size = Vector2.new(tab.button.TextBounds.X, 2),
        Color = theme.accent,
        Filled = true,
        Transparency = #self.tabs == 0 and 1 or 0,
        ZIndex = 5
    })
    
    -- Click handler
    table.insert(finchy.began, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if utility:MouseOver(tab.button.Position.X, tab.button.Position.Y, tab.button.TextBounds.X, tab.button.TextBounds.Y + 5) then
                self:SelectTab(tab)
            end
        end
    end)
    
    table.insert(self.tabs, tab)
    
    if #self.tabs == 1 then
        self.activeTab = tab
        tab.visible = true
    end
    
    -- Section creator
    function tab:CreateSection(sectionConfig)
        sectionConfig = sectionConfig or {}
        local sectionName = sectionConfig.Name or sectionConfig.name or "Section"
        local side = sectionConfig.Side or sectionConfig.side or "Left"
        
        local section = {
            name = sectionName,
            side = side,
            elements = {},
            currentY = 0,
            tab = tab,
            window = self.window,
            visible = tab.visible
        }
        
        -- Calculate position
        local baseX = self.window.position.X + 10
        local baseY = self.window.position.Y + 65
        local sectionWidth = (self.window.size.X - 30) / 2
        
        if side == "Right" then
            baseX = self.window.position.X + sectionWidth + 20
        end
        
        -- Count existing sections on same side
        local sectionCount = 0
        for _, s in pairs(tab.sections) do
            if s.side == side then
                sectionCount = sectionCount + 1
            end
        end
        
        baseY = baseY + (sectionCount * 200)
        
        section.baseX = baseX
        section.baseY = baseY
        section.width = sectionWidth
        
        -- Section background
        section.background = utility:Create("Square", {
            Position = Vector2.new(baseX, baseY),
            Size = Vector2.new(sectionWidth, 180),
            Color = theme.backgroundLight,
            Filled = true,
            Transparency = tab.visible and 1 or 0,
            ZIndex = 2
        })
        
        -- Section border
        section.border = utility:Create("Square", {
            Position = Vector2.new(baseX, baseY),
            Size = Vector2.new(sectionWidth, 180),
            Color = theme.inline,
            Filled = false,
            Thickness = 1,
            Transparency = tab.visible and 1 or 0,
            ZIndex = 3
        })
        
        -- Section title bar
        section.titleBar = utility:Create("Square", {
            Position = Vector2.new(baseX, baseY),
            Size = Vector2.new(sectionWidth, 22),
            Color = Color3.fromRGB(35, 35, 35),
            Filled = true,
            Transparency = tab.visible and 1 or 0,
            ZIndex = 3
        })
        
        -- Section accent
        section.accent = utility:Create("Square", {
            Position = Vector2.new(baseX, baseY),
            Size = Vector2.new(sectionWidth, 2),
            Color = theme.accent,
            Filled = true,
            Transparency = tab.visible and 1 or 0,
            ZIndex = 4
        })
        
        -- Section title
        section.title = utility:Create("Text", {
            Position = Vector2.new(baseX + 8, baseY + 4),
            Text = sectionName,
            Size = 13,
            Font = theme.font,
            Color = theme.textPrimary,
            Outline = true,
            OutlineColor = theme.shadow,
            Transparency = tab.visible and 1 or 0,
            ZIndex = 5
        })
        
        section.currentY = 28
        
        -- Update position function
        function section:UpdatePosition()
            local wx, wy = self.window.position.X, self.window.position.Y
            
            local newBaseX = wx + 10
            if self.side == "Right" then
                newBaseX = wx + self.width + 20
            end
            
            local sectionIndex = 0
            for i, s in pairs(self.tab.sections) do
                if s == self then break end
                if s.side == self.side then
                    sectionIndex = sectionIndex + 1
                end
            end
            
            local newBaseY = wy + 65 + (sectionIndex * 200)
            
            self.baseX = newBaseX
            self.baseY = newBaseY
            
            self.background.Position = Vector2.new(newBaseX, newBaseY)
            self.border.Position = Vector2.new(newBaseX, newBaseY)
            self.titleBar.Position = Vector2.new(newBaseX, newBaseY)
            self.accent.Position = Vector2.new(newBaseX, newBaseY)
            self.title.Position = Vector2.new(newBaseX + 8, newBaseY + 4)
            
            -- Update all elements
            for _, element in pairs(self.elements) do
                if element.UpdatePosition then
                    element:UpdatePosition()
                end
            end
        end
        
        function section:SetVisible(visible)
            self.visible = visible
            local t = visible and 1 or 0
            
            self.background.Transparency = t
            self.border.Transparency = t
            self.titleBar.Transparency = t
            self.accent.Transparency = t
            self.title.Transparency = t
            
            for _, element in pairs(self.elements) do
                if element.SetVisible then
                    element:SetVisible(visible)
                end
            end
        end
        
        -- TOGGLE
        function section:CreateToggle(toggleConfig)
            toggleConfig = toggleConfig or {}
            local toggleName = toggleConfig.Name or toggleConfig.name or "Toggle"
            local default = toggleConfig.Default or toggleConfig.default or false
            local callback = toggleConfig.Callback or toggleConfig.callback or function() end
            local flag = toggleConfig.Flag or toggleConfig.flag or nil
            
            local toggle = {
                value = default,
                section = self
            }
            
            local yPos = self.currentY
            local xPos = self.baseX + 8
            
            -- Toggle background
            toggle.background = utility:Create("Square", {
                Position = Vector2.new(xPos, self.baseY + yPos),
                Size = Vector2.new(18, 18),
                Color = theme.background,
                Filled = true,
                Transparency = self.visible and 1 or 0,
                ZIndex = 4
            })
            
            -- Toggle border
            toggle.border = utility:Create("Square", {
                Position = Vector2.new(xPos, self.baseY + yPos),
                Size = Vector2.new(18, 18),
                Color = default and theme.accent or theme.inline,
                Filled = false,
                Thickness = 1,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            -- Toggle fill (checkmark area)
            toggle.fill = utility:Create("Square", {
                Position = Vector2.new(xPos + 3, self.baseY + yPos + 3),
