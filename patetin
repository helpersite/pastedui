            if flag then
                finchy.flags[flag] = default
                finchy.pointers[flag] = keybind
            end
            
            table.insert(self.elements, keybind)
            self.currentY = self.currentY + 24
            
            return keybind
        end
        
        -- LABEL
        function section:CreateLabel(labelConfig)
            labelConfig = labelConfig or {}
            local labelText = labelConfig.Text or labelConfig.text or "Label"
            
            local label = {
                section = self
            }
            
            local yPos = self.currentY
            
            label.text = utility:Create("Text", {
                Position = Vector2.new(self.baseX + 8, self.baseY + yPos),
                Text = labelText,
                Size = 12,
                Font = theme.font,
                Color = theme.textSecondary,
                Outline = true,
                OutlineColor = theme.shadow,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            function label:Set(text)
                self.text.Text = text
            end
            
            function label:UpdatePosition()
                local s = self.section
                self.text.Position = Vector2.new(s.baseX + 8, s.baseY + yPos)
            end
            
            function label:SetVisible(visible)
                self.text.Transparency = visible and 1 or 0
            end
            
            table.insert(self.elements, label)
            self.currentY = self.currentY + 18
            
            return label
        end
        
        table.insert(tab.sections, section)
        return section
    end
    
    return tab
end

function Window:SelectTab(selectedTab)
    for _, tab in pairs(self.tabs) do
        local isSelected = tab == selectedTab
        
        tab.visible = isSelected
        tab.button.Color = isSelected and theme.accent or theme.textSecondary
        tab.underline.Transparency = isSelected and 1 or 0
        
        for _, section in pairs(tab.sections) do
            section:SetVisible(isSelected)
        end
    end
    
    self.activeTab = selectedTab
end

-- Config System
function finchy:SaveConfig(name)
    local config = {}
    
    for flag, pointer in pairs(self.pointers) do
        local value = pointer:Get()
        
        if typeof(value) == "EnumItem" then
            config[flag] = {type = "enum", value = tostring(value)}
        elseif typeof(value) == "Color3" then
            config[flag] = {type = "color", r = value.R, g = value.G, b = value.B}
        else
            config[flag] = {type = "value", value = value}
        end
    end
    
    if writefile then
        writefile(self.folders.configs .. "/" .. name .. ".json", HttpService:JSONEncode(config))
        self:Notify("Config", "Saved config: " .. name, 2, "success")
    end
end

function finchy:LoadConfig(name)
    if isfile and isfile(self.folders.configs .. "/" .. name .. ".json") then
        local config = HttpService:JSONDecode(readfile(self.folders.configs .. "/" .. name .. ".json"))
        
        for flag, data in pairs(config) do
            if self.pointers[flag] then
                if data.type == "enum" then
                    local enumType, enumValue = data.value:match("Enum%.(.+)%.(.+)")
                    if enumType and enumValue then
                        self.pointers[flag]:Set(Enum[enumType][enumValue])
                    end
                elseif data.type == "color" then
                    self.pointers[flag]:Set(Color3.new(data.r, data.g, data.b))
                else
                    self.pointers[flag]:Set(data.value)
                end
            end
        end
        
        self:Notify("Config", "Loaded config: " .. name, 2, "success")
    else
        self:Notify("Config", "Config not found: " .. name, 2, "error")
    end
end

-- Cleanup
function finchy:Destroy()
    for _, conn in pairs(self.connections) do
        if conn.Disconnect then
            conn:Disconnect()
        end
    end
    
    for _, drawing in pairs(self.drawings) do
        if drawing.Remove then
            pcall(function() drawing:Remove() end)
        end
    end
    
    self.drawings = {}
    self.connections = {}
    self.pointers = {}
    self.flags = {}
    self.began = {}
    self.changed = {}
    self.ended = {}
end

return finchy
