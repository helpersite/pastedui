        -- SLIDER
        function section:CreateSlider(sliderConfig)
            sliderConfig = sliderConfig or {}
            local sliderName = sliderConfig.Name or sliderConfig.name or "Slider"
            local min = sliderConfig.Min or sliderConfig.min or 0
            local max = sliderConfig.Max or sliderConfig.max or 100
            local default = sliderConfig.Default or sliderConfig.default or min
            local suffix = sliderConfig.Suffix or sliderConfig.suffix or ""
            local callback = sliderConfig.Callback or sliderConfig.callback or function() end
            local flag = sliderConfig.Flag or sliderConfig.flag or nil
            
            local slider = {
                value = default,
                min = min,
                max = max,
                dragging = false,
                section = self
            }
            
            local yPos = self.currentY
            local sliderWidth = self.width - 16
            
            -- Slider label
            slider.label = utility:Create("Text", {
                Position = Vector2.new(self.baseX + 8, self.baseY + yPos),
                Text = sliderName,
                Size = 12,
                Font = theme.font,
                Color = theme.textPrimary,
                Outline = true,
                OutlineColor = theme.shadow,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            -- Value text
            slider.valueText = utility:Create("Text", {
                Position = Vector2.new(self.baseX + sliderWidth - 30, self.baseY + yPos),
                Text = tostring(default) .. suffix,
                Size = 12,
                Font = theme.font,
                Color = theme.accent,
                Outline = true,
                OutlineColor = theme.shadow,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            -- Slider track
            slider.track = utility:Create("Square", {
                Position = Vector2.new(self.baseX + 8, self.baseY + yPos + 16),
                Size = Vector2.new(sliderWidth, 6),
                Color = theme.background,
                Filled = true,
                Transparency = self.visible and 1 or 0,
                ZIndex = 4
            })
            
            -- Slider track border
            slider.trackBorder = utility:Create("Square", {
                Position = Vector2.new(self.baseX + 8, self.baseY + yPos + 16),
                Size = Vector2.new(sliderWidth, 6),
                Color = theme.inline,
                Filled = false,
                Thickness = 1,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            -- Slider fill
            local fillWidth = ((default - min) / (max - min)) * sliderWidth
            slider.fill = utility:Create("Square", {
                Position = Vector2.new(self.baseX + 8, self.baseY + yPos + 16),
                Size = Vector2.new(fillWidth, 6),
                Color = theme.accent,
                Filled = true,
                Transparency = self.visible and 1 or 0,
                ZIndex = 5
            })
            
            function slider:Set(value)
                value = math.clamp(value, self.min, self.max)
                value = math.floor(value * 10) / 10
                self.value = value
                
                local percent = (value - self.min) / (self.max - self.min)
                local sliderWidth = self.section.width - 16
                self.fill.Size = Vector2.new(percent * sliderWidth, 6)
                self.valueText.Text = tostring(value) .. suffix
                
                if flag then
                    finchy.flags[flag] = value
                end
                
                callback(value)
            end
            
            function slider:Get()
                return self.value
            end
            
            function slider:UpdatePosition()
                local s = self.section
                local sw = s.width - 16
                
                self.label.Position = Vector2.new(s.baseX + 8, s.baseY + yPos)
                self.valueText.Position = Vector2.new(s.baseX + sw - 30, s.baseY + yPos)
                self.track.Position = Vector2.new(s.baseX + 8, s.baseY + yPos + 16)
                self.trackBorder.Position = Vector2.new(s.baseX + 8, s.baseY + yPos + 16)
                self.fill.Position = Vector2.new(s.baseX + 8, s.baseY + yPos + 16)
            end
            
            function slider:SetVisible(visible)
                local t = visible and 1 or 0
                self.label.Transparency = t
                self.valueText.Transparency = t
                self.track.Transparency = t
                self.trackBorder.Transparency = t
                self.fill.Transparency = t
            end
            
            -- Drag handlers
            table.insert(finchy.began, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    if self.visible and utility:MouseOver(slider.track.Position.X, slider.track.Position.Y, self.width - 16, 6) then
                        slider.dragging = true
                        local mouse = UserInputService:GetMouseLocation()
                        local percent = math.clamp((mouse.X - slider.track.Position.X) / (self.width - 16), 0, 1)
                        slider:Set(min + (max - min) * percent)
                    end
                end
            end)
            
            table.insert(finchy.changed, function()
                if slider.dragging and self.visible then
                    local mouse = UserInputService:GetMouseLocation()
                    local percent = math.clamp((mouse.X - slider.track.Position.X) / (self.width - 16), 0, 1)
                    slider:Set(min + (max - min) * percent)
                end
            end)
            
            table.insert(finchy.ended, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    slider.dragging = false
                end
            end)
            
            if flag then
                finchy.flags[flag] = default
                finchy.pointers[flag] = slider
            end
            
            table.insert(self.elements, slider)
            self.currentY = self.currentY + 28
            
            return slider
        end
        
