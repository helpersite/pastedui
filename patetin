-- Utility Functions
local utility = {}

function utility:Create(type, properties)
    local obj = Drawing.new(type)
    obj.Visible = true
    
    for prop, value in pairs(properties or {}) do
        pcall(function() obj[prop] = value end)
    end
    
    table.insert(finchy.drawings, obj)
    return obj
end

function utility:Remove(obj)
    if obj and obj.Remove then
        pcall(function() obj:Remove() end)
    end
    for i, v in pairs(finchy.drawings) do
        if v == obj then
            table.remove(finchy.drawings, i)
            break
        end
    end
end

function utility:MouseOver(x, y, w, h)
    local mouse = UserInputService:GetMouseLocation()
    return mouse.X >= x and mouse.X <= x + w and mouse.Y >= y and mouse.Y <= y + h
end

function utility:Lerp(a, b, t)
    return a + (b - a) * t
end

function utility:LerpColor(c1, c2, t)
    return Color3.new(
        utility:Lerp(c1.R, c2.R, t),
        utility:Lerp(c1.G, c2.G, t),
        utility:Lerp(c1.B, c2.B, t)
    )
end

function utility:TypeWriter(textObj, text, speed)
    speed = speed or 0.03
    textObj.Text = ""
    
    task.spawn(function()
        for i = 1, #text do
            textObj.Text = string.sub(text, 1, i)
            task.wait(speed)
        end
    end)
end

function utility:Tween(obj, props, duration)
    duration = duration or 0.2
    local startProps = {}
    local startTime = tick()
    
    for prop, _ in pairs(props) do
        startProps[prop] = obj[prop]
    end
    
    local conn
    conn = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        local alpha = math.min(elapsed / duration, 1)
        alpha = alpha * alpha * (3 - 2 * alpha) -- Smooth step
        
        for prop, target in pairs(props) do
            if typeof(target) == "Color3" then
                obj[prop] = utility:LerpColor(startProps[prop], target, alpha)
            elseif typeof(target) == "number" then
                obj[prop] = utility:Lerp(startProps[prop], target, alpha)
            elseif typeof(target) == "Vector2" then
                obj[prop] = Vector2.new(
                    utility:Lerp(startProps[prop].X, target.X, alpha),
                    utility:Lerp(startProps[prop].Y, target.Y, alpha)
                )
            end
        end
        
        if alpha >= 1 then
            conn:Disconnect()
        end
    end)
    
    table.insert(finchy.connections, conn)
end

function utility:RoundedFrame(x, y, w, h, color, zindex)
    local frames = {}
    
    -- Main body
    frames.main = utility:Create("Square", {
        Position = Vector2.new(x, y),
        Size = Vector2.new(w, h),
        Color = color,
        Filled = true,
        ZIndex = zindex or 1
    })
    
    return frames
end

function utility:GradientFrame(x, y, w, h, color1, color2, zindex)
    local frames = {}
    local steps = 10
    local stepHeight = h / steps
    
    for i = 0, steps - 1 do
        local alpha = i / (steps - 1)
        local color = utility:LerpColor(color1, color2, alpha)
        
        frames[i] = utility:Create("Square", {
            Position = Vector2.new(x, y + (i * stepHeight)),
            Size = Vector2.new(w, stepHeight + 1),
            Color = color,
            Filled = true,
            ZIndex = zindex or 1
        })
    end
    
    return frames
end

-- Notification System
function finchy:Notify(title, message, duration, type)
    duration = duration or 3
    type = type or "info"
    
    local color = type == "success" and theme.success or type == "error" and theme.error or theme.accent
    local y = 10 + (#self.notifications * 70)
    
    local notif = {}
    
    -- Background
    notif.bg = utility:Create("Square", {
        Position = Vector2.new(10, y),
        Size = Vector2.new(250, 60),
        Color = theme.background,
        Filled = true,
        ZIndex = 2000
    })
    
    -- Accent line
    notif.line = utility:Create("Square", {
        Position = Vector2.new(10, y),
        Size = Vector2.new(3, 60),
        Color = color,
        Filled = true,
        ZIndex = 2001
    })
    
    -- Border
    notif.border = utility:Create("Square", {
        Position = Vector2.new(10, y),
        Size = Vector2.new(250, 60),
        Color = theme.inline,
        Filled = false,
        Thickness = 1,
        ZIndex = 2001
    })
    
    -- Title
    notif.title = utility:Create("Text", {
        Position = Vector2.new(20, y + 8),
        Text = "",
        Size = 14,
        Font = theme.font,
        Color = color,
        Outline = true,
        OutlineColor = theme.shadow,
        ZIndex = 2002
    })
    
    -- Message
    notif.message = utility:Create("Text", {
        Position = Vector2.new(20, y + 28),
        Text = message,
        Size = 12,
        Font = theme.font,
        Color = theme.textSecondary,
        Outline = true,
        OutlineColor = theme.shadow,
        ZIndex = 2002
    })
    
    -- Progress bar
    notif.progress = utility:Create("Square", {
        Position = Vector2.new(10, y + 57),
        Size = Vector2.new(250, 3),
        Color = color,
        Filled = true,
        ZIndex = 2002
    })
    
    table.insert(self.notifications, notif)
    
    -- Typewriter title
    utility:TypeWriter(notif.title, title, 0.02)
    
    -- Progress animation
    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < duration do
            local progress = 1 - ((tick() - startTime) / duration)
            notif.progress.Size = Vector2.new(250 * progress, 3)
            task.wait()
        end
        
        -- Fade out
        utility:Tween(notif.bg, {Transparency = 0}, 0.3)
        utility:Tween(notif.line, {Transparency = 0}, 0.3)
        utility:Tween(notif.border, {Transparency = 0}, 0.3)
        utility:Tween(notif.title, {Transparency = 0}, 0.3)
        utility:Tween(notif.message, {Transparency = 0}, 0.3)
        utility:Tween(notif.progress, {Transparency = 0}, 0.3)
        
        task.wait(0.35)
        
        for _, obj in pairs(notif) do
            utility:Remove(obj)
        end
        
        for i, n in pairs(self.notifications) do
            if n == notif then
                table.remove(self.notifications, i)
                break
            end
        end
    end)
end

-- Window Class
local Window = {}
Window.__index = Window

function finchy:CreateWindow(config)
    config = config or {}
    local name = config.Name or config.name or "finchy.cc"
    local size = config.Size or config.size or Vector2.new(550, 450)
    local toggleKey = config.ToggleKey or config.toggleKey or Enum.KeyCode.RightControl
    
    local self = setmetatable({}, Window)
    
    self.name = name
    self.size = size
    self.position = Vector2.new(100, 100)
    self.visible = true
    self.dragging = false
    self.dragOffset = Vector2.new(0, 0)
    self.tabs = {}
    self.activeTab = nil
    self.toggleKey = toggleKey
    self.elements = {}
    
    -- Create main window
    self:CreateUI()
    
    -- Input handling
    local inputBegan = UserInputService.InputBegan:Connect(function(input, processed)
        if input.KeyCode == self.toggleKey then
            self:Toggle()
            return
        end
        
        if processed then return end
        
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Check dragging
            if utility:MouseOver(self.position.X, self.position.Y, self.size.X, 30) then
                self.dragging = true
                local mouse = UserInputService:GetMouseLocation()
                self.dragOffset = Vector2.new(mouse.X - self.position.X, mouse.Y - self.position.Y)
            end
            
            -- Fire element callbacks
            for _, callback in pairs(finchy.began) do
                callback(input)
            end
        end
    end)
    
    local inputChanged = UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if self.dragging then
                local mouse = UserInputService:GetMouseLocation()
                self.position = Vector2.new(mouse.X - self.dragOffset.X, mouse.Y - self.dragOffset.Y)
                self:UpdatePosition()
            end
            
            for _, callback in pairs(finchy.changed) do
                callback(input)
            end
        end
    end)
    
    local inputEnded = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.dragging = false
            
            for _, callback in pairs(finchy.ended) do
                callback(input)
            end
        end
    end)
    
    table.insert(finchy.connections, inputBegan)
    table.insert(finchy.connections, inputChanged)
    table.insert(finchy.connections, inputEnded)
    
    -- FPS/Ping counter
    local fpsConn = RunService.RenderStepped:Connect(function(dt)
        finchy.shared.fps = math.floor(1 / dt)
        finchy.shared.ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    end)
    table.insert(finchy.connections, fpsConn)
    
    finchy.shared.initialized = true
    finchy:Notify("finchy.cc", "UI Loaded Successfully!", 3, "success")
    
    return self
end

